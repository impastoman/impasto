<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Required because we declare CFBundleDocumentTypes (.stesura): NO =
	     iOS copies the shared file into our Inbox to import from (we create
	     a recipe from a copy; we never edit the user's original in place). -->
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<false/>
	<!-- App uses only standard HTTPS (no non-exempt encryption) — declaring
	     this skips the export-compliance prompt on every upload. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UIAppFonts</key>
	<array>
		<string>Fraunces-Italic-VariableFont_SOFT,WONK,opsz,wght.ttf</string>
		<string>Fraunces-VariableFont_SOFT,WONK,opsz,wght.ttf</string>
		<string>PlusJakartaSans-Italic-VariableFont_wght.ttf</string>
		<string>PlusJakartaSans-VariableFont_wght.ttf</string>
	</array>
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeDescription</key>
			<string>Stesura Recipe</string>
			<key>UTTypeIdentifier</key>
			<string>com.stesura.recipe</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeIconFiles</key>
			<array/>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>stesura</string>
				</array>
			</dict>
		</dict>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.stesura.recipe</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>stesura</string>
			</array>
		</dict>
	</array>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Stesura Recipe</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.stesura.recipe</string>
			</array>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
		</dict>
	</array>
</dict>
</plist>
